# ===========================================================================
# CITYPHARMA — single-tenant product config (this fork is locked to one agent)
# ===========================================================================
SINGLE_AGENT_MODE=1
LOCKED_PROJECT_SLUG=citypharma
PRODUCT_NAME=CityAgent Pharma
IMAGE_NAME=citypharma
IMAGE_TAG=latest

# Canonical public origin for embed snippets / SDK / docs.
# Set to your AWS domain on deploy (e.g. https://pharma.yourdomain.com).
# Leave blank for local dev — the dashboard uses the browser's own origin.
PUBLIC_URL=

# Single-tenant: no external connectors / pruned verticals — keep these on.
CONNECTOR_SCHEDULER_DISABLED=1
VERTICAL_DAEMONS_DISABLED=1
API_GW_RATE_PER_MIN=60
RUNTIME_ENV=prd

# --- Models ---
# Chat model. The bilingual (EN+Burmese) lever is the Phase-1 prompt, not the model.
CHAT_MODEL=google/gemini-3-flash-preview
# Reasoning tier — MUST be a data-policy-compliant model. qwen/qwen3-max-thinking
# 404s ("No endpoints matching your data policy") and breaks analytical chat.
# gemini-3-flash primary (honors the Burmese override) + gpt-5-mini as the
# OpenRouter models[] fallback (wired in app/projects.py tier model).
REASONING_MODEL=google/gemini-3-flash-preview
APIGW_LOG_BODIES=1

# --- Caching ---
# PROD (recommended): caching ON — it hides the 70-220s repeat-question latency.
APIGW_CACHE_TTL=90
METRIC_SHORTCUT_DISABLED=0
# DEV: set APIGW_CACHE_TTL=0 and METRIC_SHORTCUT_DISABLED=1 so tests/evals see
# real fresh behaviour (no 0s cache hits).

# ===========================================================================
# REQUIRED — app won't start without these
# ===========================================================================

# Get from: https://openrouter.ai/keys
# Account privacy must allow training-permitted providers
# (openrouter.ai/settings/privacy) or models 404 on the data policy.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Multi-key pool (preferred for >10 concurrent users — escapes per-key 429 ceiling).
# Semicolon-separated. Pool rotates least-in-flight, per-key 429 cooldown 30s.
# If set, OPENROUTER_API_KEY is also folded into the pool.
# OPENROUTER_API_KEYS=sk-or-v1-key1;sk-or-v1-key2;sk-or-v1-key3
# OPENROUTER_POOL_MAX_CONNECTIONS=100
# OPENROUTER_POOL_MAX_CONNECTIONS_PER_HOST=30
# OPENROUTER_429_COOLDOWN_SECONDS=30
# OPENROUTER_MAX_RETRIES=3

# Database password — CHANGE THIS
DB_PASS=ai

# Your domain — CHANGE THIS
DOMAIN=localhost

# CORS — set to your exact domain(s), comma-separated (e.g.
# https://pharma.yourdomain.com,https://admin.yourdomain.com).
# Blank → falls back to PUBLIC_URL; if that is also blank, allows all origins
# WITHOUT credentials (safe-but-open). NEVER ship "*" with real users.
CORS_ORIGINS=

# ===========================================================================
# CONFIGURABLE — change if needed
# ===========================================================================

# Admin account
SUPER_ADMIN=admin
SUPER_ADMIN_PASS=admin

# Database
DB_USER=ai
DB_DATABASE=ai

# Workers — size to RAM, not CPU. Each worker loads the full agent stack
# (heavy). Default (unset) caps at min(8, cpu_count). ~1-2 workers per GB RAM.
# 5-10 users: 2, 10-30 users: 4, 30-100 users: 8. 16 needs a big box (16GB+).
WORKERS=8

# LLM concurrency control (prevents OpenRouter rate-limit failures)
LLM_PARALLEL_CAP=5              # default cap when tier cannot be inferred
LLM_PARALLEL_CAP_CHAT=20        # concurrent agent runs, chat tier (embed + chat share it). 20 = true 20-store-parallel embed load
LLM_PARALLEL_CAP_DEEP=3         # cap for heavy reasoning tier (DEEP_MODEL)
LLM_PARALLEL_CAP_LITE=20        # cap for cheap/fast tier (LITE_MODEL)
# LLM_POOL_SIZE=38              # thread pool size; default = sum of caps + 5

ORG_RATE_LIMIT_EMBED=300        # per-org combined limit for embed chat (sliding 1 min)

# Embedding model — leave commented to use the default cascade (recommended).
# Default cascade order (first success wins):
#   1. openai/text-embedding-3-small  (native 1536 — no truncation, matches dash_vectors schema)
#   2. openai/text-embedding-3-large  (3072 → 1536 clean reduction via `dimensions` param)
#   3. google/gemini-embedding-2-preview  (3072 → 1536 truncated, lossy but functional)
#   4. cohere/embed-v4.0  (last resort)
# EMBEDDING_MODEL=openai/text-embedding-3-small  # native 1536 — no truncation

# ===========================================================================
# OPTIONAL — skip if not needed
# ===========================================================================

# ---------------------------------------------------------------------------
# Federated auth (LDAP + OIDC/SSO) — OpenWebUI-modeled. All OFF by default;
# local username/password always works. Non-secret config is also editable
# live at /ui/auth-admin (super-admin). SECRETS BELOW STAY IN ENV ONLY.
# ---------------------------------------------------------------------------
# LOCAL_AUTH_ENABLED=true                 # set false to force SSO/LDAP only
# OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true      # link SSO/LDAP identity to existing local user by email
# WEBUI_AUTH_TRUSTED_EMAIL_HEADER=        # advanced: trust this proxy header as the user email (off unless behind a trusted SSO gateway)
# PUBLIC_URL=https://pharma.yourdomain.com  # external base, used to build the OIDC callback URL

# --- LDAP / Active Directory (bind-search-bind) ---
# ENABLE_LDAP=true
# LDAP_SERVER_HOST=ldap.yourdomain.com    # hostname only, no protocol
# LDAP_SERVER_PORT=389                     # 389 plaintext/StartTLS, 636 LDAPS
# LDAP_USE_TLS=false
# LDAP_VALIDATE_CERT=true
# LDAP_APP_DN=cn=svc-account,dc=ex,dc=com  # service bind account
# LDAP_APP_PASSWORD=                        # SECRET — service bind password
# LDAP_SEARCH_BASE=ou=users,dc=ex,dc=com
# LDAP_ATTRIBUTE_FOR_USERNAME=uid           # sAMAccountName on AD
# LDAP_ATTRIBUTE_FOR_MAIL=mail
# LDAP_ATTRIBUTE_FOR_GROUPS=memberOf
# LDAP_SEARCH_FILTER=                        # optional extra filter, e.g. (objectClass=person)

# --- Keycloak SSO (convenience; becomes an OIDC provider id 'keycloak') ---
# KEYCLOAK_URL=https://keycloak.yourdomain.com
# KEYCLOAK_REALM=dash
# KEYCLOAK_CLIENT_ID=dash-app
# KEYCLOAK_CLIENT_SECRET=                    # SECRET

# --- Generic OIDC (Keycloak/Authentik/Okta/Azure/etc) — provider id 'oidc' ---
# OPENID_PROVIDER_URL=https://idp.example.com/realms/myrealm   # issuer (has /.well-known/openid-configuration)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=                       # SECRET (also OIDC_<ID>_CLIENT_SECRET for extra providers)
# OAUTH_PROVIDER_NAME=SSO
# OAUTH_SCOPES=openid email profile
# OAUTH_EMAIL_CLAIM=email
# OAUTH_USERNAME_CLAIM=preferred_username
# OAUTH_ROLES_CLAIM=roles                    # leave OAUTH_ALLOWED_ROLES blank to allow everyone
# OAUTH_ALLOWED_ROLES=                       # comma list; if set, user must hold one or login is rejected
# OAUTH_GROUPS_CLAIM=groups                  # group→branch (site_code) map editable at /ui/auth-admin (advanced JSON)

# --- Google / Microsoft built-ins (SECRETS in env) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Slack notifications
# SLACK_TOKEN=xoxb-your-token
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# OPT-IN FEATURE FLAGS (all default OFF — 2026-05-20 scope trim)
# Set to 1 to re-enable. Left off keeps base Dash lean (chat-first analytics).
# ---------------------------------------------------------------------------
# AUTOML_ENABLED=1               # mount /api/automl + ML Insights nav (DataRobot-style AutoML)
# SIM_LAB_ENABLED=1              # mount /api/sim + Sim Lab nav + chat sim-routing + Leader SIM rule
# INVESTMENT_VERTICAL_ENABLED=1  # mount /api/investment + investment agents on financial-table projects
# ONTOLOGY_CLUSTER_ENABLED=1     # nightly entity auto-merge daemon (was default-on, now opt-in)
# BENCHMARK_SYNC_ENABLED=1       # weekly industry-KPI fetch daemon (was default-on, now opt-in)

# ---------------------------------------------------------------------------
# Observability — Sentry errors + Prometheus /metrics + backup retention
# ---------------------------------------------------------------------------
# Leave SENTRY_DSN empty to disable Sentry entirely.
SENTRY_DSN=
DASH_ENV=dev
# Set DASH_DEBUG=1 to expose /api/_debug/sentry-test (forces an error).
DASH_DEBUG=
# Trace sample rate for Sentry performance monitoring (0.0–1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1
# Nightly pg_dump retention (days). dash-backup compose service handles cron + prune.
BACKUP_RETENTION_DAYS=7

# Embed chat cache (Redis)
REDIS_URL=redis://dash-redis:6379/2
EMBED_CACHE_TTL=300
EMBED_CACHE_DISABLED=

# ---------------------------------------------------------------------------
# Context-exhaustion guards + per-tool tracing (all fail-open)
# ---------------------------------------------------------------------------
# Token budget for a single tool result before it is truncated + paginated.
TOOL_RESULT_MAX_TOKENS=25000
# How many recent conversation turns keep their tool-result content; older
# tool results are elided to a stub to free context.
CONTEXT_EDIT_KEEP_TURNS=6
# Set truthy (1/true/yes) to disable the context guards entirely.
CONTEXT_GUARDS_DISABLED=
# Set truthy to disable durable per-tool reasoning-trace spans (dash_traces).
TRACING_DISABLED=

# ---------------------------------------------------------------------------
# Continuous query learning + curator (learns/reuses the agent's own live SQL)
# ---------------------------------------------------------------------------
QUERY_BANK_SERVE_SIM=0.93        # Mode-1 zero-LLM serve threshold
QUERY_BANK_RECALL_SIM=0.80       # Mode-2 hint floor
QUERY_BANK_EMB_TTL=300           # question-embedding cache TTL (L1 + Redis)
QUERY_CURATOR_ENABLED=1          # 24h leader daemon auto-promotes learned queries
QUERY_CURATOR_MIN_USES=3         # a candidate must recur this many times first
QUERY_CURATOR_MAX_PROMOTE=10     # max auto-promotes per cycle
QUERY_CURATOR_CROSSCHECK=1       # require an independent fresh-SQL to agree before promote

# ---------------------------------------------------------------------------
# NO DEMO DATA. The product ships none and cannot generate any (removed v1.30.0).
# A fresh install is EMPTY — upload real catalog + stock, then Force-Train.
# ===========================================================================
# DEPLOY: cp .env.example .env → edit → docker compose up -d --build
# PROD must-set: OPENROUTER_API_KEY, DB_PASS, SUPER_ADMIN_PASS, PUBLIC_URL,
#   DOMAIN, CORS_ORIGINS (never "*"). Keep caching ON (APIGW_CACHE_TTL=90,
#   METRIC_SHORTCUT_DISABLED=0) and DASH_DEBUG blank.
# DB IMAGE: must be the AGE-baked one (db/Dockerfile.age → cp-db-age:pg18) or
#   Postgres won't boot (the substitutes graph needs age.so). Don't recreate
#   cp-db on a non-AGE image.
# LOGIN: admin / admin → change password after first login
# ===========================================================================
