# CityPharma — all-shops config.
# Replace this file with the admin "Copy .env" download (Outlet Keys panel):
# it contains CITYPHARMA_BASE + one CITYPHARMA_KEY_<outlet> line per branch.
#
# Streaming + live agent thinking are enabled in code via:
#   POST body {"stream": true}  +  header  X-Agent-Steps: 1
# Warm pharmacist formatting is applied server-side automatically.

CITYPHARMA_BASE=__CITYPHARMA_BASE__

# one line per outlet — outlet code with '-' written as '_'
CITYPHARMA_KEY_20003_CCJ8=dash-key-XXXXXXXXXXXXXXXXXXXXXXXX
CITYPHARMA_KEY_20004_CCFMI=dash-key-XXXXXXXXXXXXXXXXXXXXXXXX
# ... (53 outlets — full list in the Copy .env download)
