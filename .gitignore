# secrets
.env
.env.*
!.env.example
*.key
*.pem
# service keys / test fixtures with live keys + result data
examples/outlet-test/fixtures.json
examples/outlet-test/results*.csv
# db dumps / sql snapshots
*.dump
*.sql
# ...but DB migrations and the fresh-install baseline schema MUST be tracked
# (they are app source, not ad-hoc dumps). Without these negations *.sql above
# silently excludes them → a fresh clone deploys with no schema.
!db/migrations/*.sql
!db/baseline/*.sql
# python
__pycache__/
*.pyc
.venv/
venv/
# node / sveltekit
node_modules/
frontend/node_modules/
frontend/.svelte-kit/
# build output (regenerated by docker build — must NOT be in git)
frontend/build/
# misc
.DS_Store
/tmp/
# other-tenant / demo training data (not part of the single-tenant citypharma app)
knowledge/proj_*
knowledge/proj_demo_*
knowledge/proj_admin_*
knowledge_backup_*/
knowledge_backup_*.json
# dev tester with a hardcoded live gateway key
examples/php-tester/
# all training/knowledge data (real business data; regenerated by training)
knowledge/

# embed load-test artifacts (per-embed keys + result data)
examples/embed-test/embed_fixtures.json
examples/embed-test/embed_results.csv
examples/embed-test/store_embeds.tsv
