# ===========================================================================
# CITYPHARMA — PRODUCTION env template
# Copy to .env on the cloud box, fill the 🔴 values, then deploy.
#   cp .env.production.example .env  →  edit  →  docker compose up -d --build
# .env is gitignored — NEVER commit real secrets.
# ===========================================================================

# ── Single-tenant product lock (do not change) ──────────────────────────────
SINGLE_AGENT_MODE=1
LOCKED_PROJECT_SLUG=citypharma
PRODUCT_NAME=CityAgent Pharma
IMAGE_NAME=citypharma
IMAGE_TAG=latest
RUNTIME_ENV=prd
DASH_ENV=prod
# Keep blank in prod — gates traceback leakage to clients. Set 1 only to debug.
DASH_DEBUG=

# ===========================================================================
# 🔴 MUST SET — deploy is not safe until these are real values
# ===========================================================================

# 🔴 OpenRouter key. https://openrouter.ai/keys — account privacy MUST allow
# training-permitted providers (openrouter.ai/settings/privacy) or models 404.
OPENROUTER_API_KEY=sk-or-v1-CHANGE-ME

# 🔴 Database password (do NOT ship the dev default).
DB_PASS=CHANGE-ME-strong-db-password

# 🔴 Super-admin login. This is the only admin account on a fresh box.
SUPER_ADMIN=admin
SUPER_ADMIN_PASS=CHANGE-ME-strong-admin-password

# 🔴 Your public origin (drives every embed/gateway/SDK URL shown to devs).
PUBLIC_URL=https://pharma.yourdomain.com

# 🔴 Your domain (Caddy / TLS).
DOMAIN=pharma.yourdomain.com

# 🔴 CORS — exact origin(s), comma-separated. NEVER "*" with real users.
# Blank → falls back to PUBLIC_URL; if that is also blank → allow-all WITHOUT
# credentials (open but credential-safe). Set it explicitly for prod.
CORS_ORIGINS=https://pharma.yourdomain.com

# ===========================================================================
# Models (data-policy-compliant; do not swap to qwen-thinking — it 404s)
# ===========================================================================
CHAT_MODEL=google/gemini-3-flash-preview
REASONING_MODEL=google/gemini-3-flash-preview
# EMBEDDING_MODEL=openai/text-embedding-3-small   # leave commented = default cascade

# Multi-key pool (preferred for >10 concurrent users — escapes per-key 429).
# Semicolon-separated; OPENROUTER_API_KEY is folded in too.
# OPENROUTER_API_KEYS=sk-or-v1-key1;sk-or-v1-key2;sk-or-v1-key3

# ===========================================================================
# Caching — PROD = ON. These hide the 70-220s repeat-question latency.
# (DEV uses APIGW_CACHE_TTL=0 + METRIC_SHORTCUT_DISABLED=1 to see fresh behaviour.)
# ===========================================================================
APIGW_CACHE_TTL=90
METRIC_SHORTCUT_DISABLED=0
APIGW_LOG_BODIES=1

# ===========================================================================
# Continuous query learning + curator (learns/reuses the agent's own SQL)
# ===========================================================================
# Mode-1 zero-LLM serve threshold + Mode-2 hint floor. Tuned on synthetic
# paraphrases — RE-VALIDATE on real traffic (admin Query Bank / shadow table).
QUERY_BANK_SERVE_SIM=0.93
QUERY_BANK_RECALL_SIM=0.80
QUERY_BANK_EMB_TTL=300
# Curator daemon: auto-promotes learned queries to instant-serve. It is a WRITER.
# Gates: recur >= MIN_USES, no thumbs-down, cap per cycle, AND an independent
# fresh-SQL correctness cross-check must agree. ON is safe with the gates; for a
# brand-new customer you may prefer MIN_USES=5 or curate by hand (set =0).
QUERY_CURATOR_ENABLED=1
QUERY_CURATOR_MIN_USES=3
QUERY_CURATOR_MAX_PROMOTE=10
QUERY_CURATOR_CROSSCHECK=1

# ===========================================================================
# Single-tenant hygiene (keep on) + capacity
# ===========================================================================
CONNECTOR_SCHEDULER_DISABLED=1
VERTICAL_DAEMONS_DISABLED=1
APIGW_AUTO_PROVISION=0
API_GW_RATE_PER_MIN=60

DB_USER=ai
DB_DATABASE=ai

# Workers — size to RAM (each loads the full agent stack). Default caps at
# min(8, cpu). 5-10 users:2 · 10-30:4 · 30-100:8 (16 needs 16GB+).
WORKERS=8
LLM_PARALLEL_CAP=5
LLM_PARALLEL_CAP_CHAT=20
LLM_PARALLEL_CAP_DEEP=3
LLM_PARALLEL_CAP_LITE=20
ORG_RATE_LIMIT_EMBED=300

# Redis (embed answer cache + query-bank embed cache + rate limits)
REDIS_URL=redis://dash-redis:6379/2
EMBED_CACHE_TTL=300

# ===========================================================================
# Observability (optional)
# ===========================================================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
BACKUP_RETENTION_DAYS=7

# ===========================================================================
# NO DEMO DATA. The product ships none and cannot generate any (v1.30.0). A
# fresh install is EMPTY — upload your real catalog + stock, then Force-Train.
#
# DEPLOY NOTES:
#  • DB image MUST be the AGE-baked one (db/Dockerfile.age → cp-db-age:pg18) or
#    Postgres won't boot (the substitutes graph needs age.so). Don't recreate
#    cp-db on a non-AGE image.
#  • First login: SUPER_ADMIN / SUPER_ADMIN_PASS above.
# ===========================================================================
